# Enable rewrite engine
RewriteEngine On

# Redirect www to non-www
RewriteCond %{HTTP_HOST} ^www\.learndocs-hub\.com$ [NC]
RewriteRule ^(.*)$ https://learndocs-hub.com/$1 [L,R=301]

# Redirect HTTP to HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://learndocs-hub.com/$1 [L,R=301]

# Service Worker
<FilesMatch "service-worker\.js$">
  Header set Service-Worker-Allowed "/"
</FilesMatch>

# Cache static assets
<FilesMatch "\.(html|css|js|json|svg)$">
  Header set Cache-Control "public, max-age=0, must-revalidate"
</FilesMatch>

<FilesMatch "\.(png|jpg|jpeg|gif|webp|ico|woff|woff2)$">
  Header set Cache-Control "public, max-age=31536000"
</FilesMatch>

# Security headers
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "SAMEORIGIN"
Header always set X-XSS-Protection "1; mode=block"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header always set Content-Security-Policy "default-src 'self' https://fonts.googleapis.com https://fonts.gstatic.com https://unpkg.com https://cdnjs.cloudflare.com https://api.groq.com; script-src 'self' 'unsafe-inline' https://unpkg.com https://cdnjs.cloudflare.com https://www.googletagmanager.com https://www.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data:; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://api.groq.com"

# Compresion
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/ld+json
</IfModule>
